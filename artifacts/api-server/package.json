    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/integration-contracts": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "csv-parse": "^6.2.1",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "fflate": "^0.8.2",
    "google-auth-library": "^10.6.2",
